{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@workspace/db": ["../../lib/db/src/index.ts"],
      "@workspace/api-zod": ["../../lib/api-zod/src/generated/api.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
